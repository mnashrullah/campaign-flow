# ---- core ----
NODE_ENV=development
PORT=4000
CORS_ORIGIN=*
DATABASE_URL=postgres://campaign:campaign@localhost:5432/campaign_flow
REDIS_URL=redis://localhost:6379

# ---- provider selection ----
# dryrun | ses | resend
PROVIDER=dryrun

# ---- sending shape (shared) ----
CHUNK_SIZE=500
WORKER_CONCURRENCY=24
MAX_ATTEMPTS=3
CLAIM_TIMEOUT_MS=120000
FROM_EMAIL=Campaign Flow <no-reply@example.com>
UNSUBSCRIBE_BASE_URL=http://localhost:4000/unsubscribe

# ---- per-provider limits (AIMD ceiling + batch size) ----
DRYRUN_RATE_PER_SEC=2000
DRYRUN_MAX_BATCH=100
SES_RATE_PER_SEC=14
SES_MAX_BATCH=50
SES_REGION=us-east-1
# SES_CONFIGURATION_SET=my-config-set
RESEND_RATE_PER_SEC=10
RESEND_MAX_BATCH=100
# RESEND_API_KEY=re_xxx

# ---- dry-run simulation (fractions of messages) ----
DRYRUN_LATENCY_MS=25
DRYRUN_INVALID_RATE=0.01
DRYRUN_TRANSIENT_ERROR_RATE=0.02
DRYRUN_HARD_FAIL_RATE=0.005
DRYRUN_BOUNCE_RATE=0.01
DRYRUN_COMPLAINT_RATE=0.0002
DRYRUN_THROTTLE_RATE=0.0

# ---- AIMD throughput controller ----
AIMD_ENABLED=true
AIMD_TICK_MS=2000
AIMD_START_RATE=200
AIMD_MIN_RATE=50
AIMD_INCREASE_STEP=200
AIMD_DECREASE_FACTOR=0.5

# ---- reputation circuit-breaker ----
BREAKER_ENABLED=true
BREAKER_BOUNCE_THRESHOLD=0.05
BREAKER_COMPLAINT_THRESHOLD=0.001
BREAKER_MIN_SAMPLE=500
BREAKER_COOLDOWN_MS=30000

# ---- background loops ----
REAPER_TICK_MS=15000
RECONCILER_TICK_MS=10000
